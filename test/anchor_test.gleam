pub fn github_slugger_fixtures_test() {
  list.fold(fixtures(), anchor.new(), fn(anchorer, fixture) {
    let #(input, expected) = fixture
    let #(anchorer, got) = anchor.anchor(anchorer, input)
    got |> should.equal(expected)
    anchorer
  })
}

pub fn to_anchor_is_stateless_test() {
  anchor.to_anchor("alpha") |> should.equal("alpha")
  anchor.to_anchor("alpha") |> should.equal("alpha")
}

pub fn to_anchor_keeps_underscores_test() {
  anchor.to_anchor("Hello, _World_!") |> should.equal("hello-_world_")
}

pub fn to_anchor_does_not_collapse_spaces_test() {
  anchor.to_anchor("a  b") |> should.equal("a--b")
}

pub fn maintaining_case_test() {
  anchor.to_anchor_maintaining_case("Hello, World!")
  |> should.equal("Hello-World")
}

pub fn anchor_maintaining_case_unique_test() {
  let a = anchor.new()
  let #(a, first) = anchor.anchor_maintaining_case(a, "Intro")
  let #(_, second) = anchor.anchor_maintaining_case(a, "Intro")
  first |> should.equal("Intro")
  second |> should.equal("Intro-1")
}
